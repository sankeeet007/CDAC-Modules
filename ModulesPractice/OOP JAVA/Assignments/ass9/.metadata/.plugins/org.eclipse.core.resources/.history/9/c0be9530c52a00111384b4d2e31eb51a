package javafile;

import java.io.File;
import java.io.FileOutputStream;
import java.io.IOException;
import java.io.PrintWriter;
import java.util.ArrayList;

public class CreateClass {
	static String path;
	static void setPath(String p){
		path = p;
	}
	static public void getClass(String classname) {
		String str = classname.replace(".", File.separator);
		setPath(str);
		int ind = str.lastIndexOf('\\');
		str = str.substring(0,ind);
		System.out.println(str);
		
		File fobj = new File("C:\\"+str);
		if(!fobj.exists()) {
			fobj.mkdirs();
		}
	}
	
	static void generateClass(ArrayList<String>farr,ArrayList<String>marr)
	{
		try (FileOutputStream fobj = new FileOutputStream(path+".java");
				PrintWriter pobj = new PrintWriter(fobj)) {
			
			pobj.println("package "+path+";");
			pobj.println();
			int ind = path.lastIndexOf('\\');
			String st = path.substring(ind);
			pobj.println("class " + st +"{");
			for(String tr:farr) {
				pobj.println(tr);				
			}
			for(String tr:marr) {
				pobj.println(tr + "{\n}" );
			}
			pobj.println();
			pobj.println("}");
//			pobj.println(path);
		} catch (IOException e) {
			// TODO Auto-generated catch block
			e.printStackTrace();
		}
	}
}