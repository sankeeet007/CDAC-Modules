2) Create a procedure that accepts a department number and displays:
a. Total employees in that department
b. Average salary
c. Highest salary
d. Lowest salary


	DELIMITER //
	CREATE PROCEDURE P9(IN p_deptno INT)
	BEGIN
		SELECT 
			COUNT(*) AS 'Total_Emp',
			AVG(sal) AS 'Average_Sal',
			MAX(sal) AS 'Highest_Sal',
			MIN(sal) AS 'Lowest_Sal'
		FROM 
			emp
		WHERE
			deptno = p_deptno;
	END //
	DELIMITER ;


3) Create a copy of emp table as emp_sp.
Create a stored procedure that:
a. Accepts employee number and increment percentage
b. Updates the salary accordingly in the emp_sp table
c. Displays old salary and new salary

	CREATE TABLE emp_sp AS SELECT * FROM emp;

	DELIMITER //

	CREATE PROCEDURE P10(
		IN p_empno INT, 
		IN p_increment_pct DECIMAL(5,2)
	)
	BEGIN
		DECLARE v_old_sal DECIMAL(10,2);
		DECLARE v_new_sal DECIMAL(10,2);

		SELECT SAL INTO v_old_sal 
		FROM emp_sp 
		WHERE EMPNO = p_empno;

		IF v_old_sal IS NOT NULL THEN
			UPDATE emp_sp 
			SET SAL = SAL + (SAL * (p_increment_pct / 100))
			WHERE EMPNO = p_empno;

			SELECT SAL INTO v_new_sal 
			FROM emp_sp 
			WHERE EMPNO = p_empno;

			SELECT 
				p_empno AS Employee_ID,
				v_old_sal AS Old_Salary, 
				v_new_sal AS New_Salary;
		ELSE
			SELECT 'Employee not found' AS Error_Message;
		END IF;
	END //

	DELIMITER ;

4) Create a procedure to insert a new employee into emp_sp table. The procedure should:
a. Accept all required employee details as parameters
b. Validate that EMPNO does not already exist
c. If exists → return a message
d. Else → insert record

	DELIMITER //

	CREATE PROCEDURE P11(
		IN p_empno INT,
		IN p_ename VARCHAR(10),
		IN p_job VARCHAR(9),
		IN p_mgr INT,
		IN p_hiredate DATE,
		IN p_sal DECIMAL(7,2),
		IN p_comm DECIMAL(7,2),
		IN p_deptno INT
	)
	BEGIN
		IF EXISTS (SELECT 1 FROM emp_sp WHERE EMPNO = p_empno) THEN
			SELECT CONCAT('Error: Employee Number ', p_empno, ' already exists.') AS Status;
		ELSE
			INSERT INTO emp_sp (EMPNO, ENAME, JOB, MGR, HIREDATE, SAL, COMM, DEPTNO)
			VALUES (p_empno, p_ename, p_job, p_mgr, p_hiredate, p_sal, p_comm, p_deptno);
		  
			SELECT CONCAT('Success: Employee ', p_ename, ' has been added.') AS Status;
		END IF;
	END //

	DELIMITER ;

5) Create a procedure that accepts department number and displays employees who earn more than the average salary of that department.

	DELIMITER //

	CREATE PROCEDURE P12(IN p_deptno INT)
	BEGIN
		SELECT 
			EMPNO, 
			ENAME, 
			SAL, 
			DEPTNO
		FROM 
			emp
		WHERE 
			DEPTNO = p_deptno
			AND SAL > (
				SELECT AVG(SAL) 
				FROM emp 
				WHERE DEPTNO = p_deptno
			);
	END //

	DELIMITER ;

6) Create a procedure that:
a. Accepts department number
b. Calculates total salary expense from emp table
c. If total expense > 10000 → display “High Expense Department”
d. Else → display “Normal Expense Department”

	DELIMITER //

	CREATE PROCEDURE P13(IN p_deptno INT)
	BEGIN
		DECLARE v_total_expense DECIMAL(10,2);

		SELECT SUM(SAL) INTO v_total_expense
		FROM emp
		WHERE DEPTNO = p_deptno;

		IF v_total_expense IS NULL THEN
			SELECT 'Department is empty or does not exist' AS Result;
		ELSEIF v_total_expense > 10000 THEN
			SELECT v_total_expense AS Total_Salary, 'High Expense Department' AS Status;
		ELSE
			SELECT v_total_expense AS Total_Salary, 'Normal Expense Department' AS Status;
		END IF;
	END //

	DELIMITER ;

7) Create a procedure that:
a. Accepts employee number
b. Based on salary, returns grade:
c. SAL >= 3000 → Grade A
d. SAL between 2000 and 2999 → Grade B
e. SAL < 2000 → Grade C

	DELIMITER //
	CREATE PROCEDURE P14(IN p_empno INT)
	BEGIN
		SELECT sal, case
		WHEN sal >= 3000 THEN 'A'
		WHEN sal BETWEEN 2000 AND 2999 THEN 'B'
		WHEN sal < 2000 THEN 'C'
		END AS 'GRADE'
		FROM emp
		WHERE empno = p_empno;
	END //
	DELIMITER ;
		
	

8) Create a procedure that accepts a year and:
a. Displays total employees hired in that year
b. Displays average salary of those employees

	DELIMITER //

	CREATE PROCEDURE P15(IN p_year INT)
	BEGIN
		SELECT 
			COUNT(*) AS Total_Employees_Hired,
			ROUND(AVG(SAL), 2) AS Average_Salary
		FROM 
			emp
		WHERE 
			YEAR(HIREDATE) = p_year;
	END //

	DELIMITER ;

9) Create a copy of Emp table as “Emp_Copy”. Ensure all records of emp get copied in the new table. Create a procedure that will add a new record in Emp_Copy table as per following
specifications:
a. Accepts all employee details as IN parameters
b. Returns via OUT parameter:
c. Status Message should be "Inserted Successfully" if the new empno is unique. And the record should get added in the Emp_Copy table.
d. Else if the empno is duplicate then the message should be "Employee Already Exists" and records should not get added in the Emp_Copy table.

	CREATE TABLE Emp_Copy AS SELECT * FROM emp;

	DELIMITER //

	CREATE PROCEDURE P16(
		IN p_empno INT,
		IN p_ename VARCHAR(10),
		IN p_job VARCHAR(9),
		IN p_mgr INT,
		IN p_hiredate DATE,
		IN p_sal DECIMAL(7,2),
		IN p_comm DECIMAL(7,2),
		IN p_deptno INT,
		OUT p_status VARCHAR(50) 
	)
	BEGIN
		IF EXISTS (SELECT 1 FROM Emp_Copy WHERE EMPNO = p_empno) THEN
			SET p_status = 'Employee Already Exists';
		ELSE
			INSERT INTO Emp_Copy (EMPNO, ENAME, JOB, MGR, HIREDATE, SAL, COMM, DEPTNO)
			VALUES (p_empno, p_ename, p_job, p_mgr, p_hiredate, p_sal, p_comm, p_deptno);
			
			SET p_status = 'Inserted Successfully';
		END IF;
	END //

	DELIMITER ;

10) There are two tables namely Customers_2026 and Transactions_2026. 

Customers_2026 table structure:
No. ColumnName Data Type Constraints
1 CustID Numeric Primary Key
2 CustName String Cannot be blank
3 Cust_Bill_Number Numeric Cannot be less than 500
4 CustPassport_No String Can be blank but cannot repeat

Transactions_2026 table structure:
No. ColumnName Data Type Constraints
1 CustID Numeric Must be taken from Customer_2026 table & it is mandatory.
2 CusTrID Numeric Primary Key and Auto number
3 Amount Numeric Cannot be negative and cannot exceed 100000

Create the above two tables by applying all the constraints.
There will be a Error_Log_table.
It’s structure will be as follows:

No. ColumnName Data Type
1 RecID Numeric (Auto number)
2 Error_date Date
3 Error_Number Numeric
4 Error_Message String

Create a Procedure named “Add_Record” which will take customer id, name, bill no, passport number and amount as the parameters.
The procedure should add record in both the tables. In case of any error the error details should go in the table named Error_Log_table.

	-- 1. Customers Table
	CREATE TABLE Customers_2026 (
		CustID INT PRIMARY KEY,
		CustName VARCHAR(100) NOT NULL,
		Cust_Bill_Number INT,
		CustPassport_No VARCHAR(50) UNIQUE,
		-- Constraints
		CONSTRAINT chk_CustName CHECK (TRIM(CustName) <> ''), 
		CONSTRAINT chk_BillNo CHECK (Cust_Bill_Number >= 500)
	);

	-- 2. Transactions Table
	CREATE TABLE Transactions_2026 (
		CusTrID INT AUTO_INCREMENT PRIMARY KEY,
		CustID INT NOT NULL,
		Amount DECIMAL(10,2),
		-- Constraints
		CONSTRAINT fk_cust_trans FOREIGN KEY (CustID) REFERENCES Customers_2026(CustID),
		CONSTRAINT chk_Amount CHECK (Amount >= 0 AND Amount <= 100000)
	);

	-- 3. Error Log Table
	CREATE TABLE Error_Log_table (
		RecID INT AUTO_INCREMENT PRIMARY KEY,
		Error_date DATE,
		Error_Number INT,
		Error_Message VARCHAR(500)
	);

	DELIMITER //

	CREATE PROCEDURE P17(
		IN p_custid INT,
		IN p_custname VARCHAR(100),
		IN p_bill_no INT,
		IN p_passport_no VARCHAR(50),
		IN p_amount DECIMAL(10,2)
	)
	BEGIN
		DECLARE v_err_no INT;
		DECLARE v_err_msg VARCHAR(500);

		DECLARE EXIT HANDLER FOR SQLEXCEPTION
		BEGIN
			GET DIAGNOSTICS CONDITION 1
				v_err_no = MYSQL_ERRNO, 
				v_err_msg = MESSAGE_TEXT;
			
			ROLLBACK;
			
			INSERT INTO Error_Log_table (Error_date, Error_Number, Error_Message)
			VALUES (CURDATE(), v_err_no, v_err_msg);
		END;

		START TRANSACTION;

		IF p_passport_no = '' THEN
			SET p_passport_no = NULL;
		END IF;

		INSERT INTO Customers_2026 (CustID, CustName, Cust_Bill_Number, CustPassport_No)
		VALUES (p_custid, p_custname, p_bill_no, p_passport_no);

		INSERT INTO Transactions_2026 (CustID, Amount)
		VALUES (p_custid, p_amount);

		COMMIT;

	END //

	DELIMITER ;
